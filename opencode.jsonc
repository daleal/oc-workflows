{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["./src/server.ts"],
  "formatter": {
    "eslint": { "disabled": true },
    "oxfmt": {
      "command": ["bunx", "oxfmt", "$FILE"],
      "extensions": [
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".html",
        ".htm",
        ".css",
        ".scss",
        ".sass",
        ".less",
        ".vue",
        ".svelte",
        ".json",
        ".jsonc",
        ".yaml",
        ".yml",
        ".toml",
        ".xml",
        ".md",
        ".mdx",
        ".graphql",
        ".gql",
      ],
    },
  },
  "lsp": {
    "oxlint": {
      "command": ["bun", "run", "oxlint", "--lsp"],
    },
  },
  "references": {
    "opencode": {
      "repository": "github.com/anomalyco/opencode",
      "description": "The OpenCode upstream repository",
    },
  },
}
